// SAB India Project Tracker — Prisma schema
// All money uses Decimal; timestamps are UTC in DB and rendered in IST at the edge.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  SUPERVISOR
  EMPLOYEE
}

enum EmploymentType {
  HOURLY
  SALARIED
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum BudgetCategory {
  MATERIAL
  LABOR
  OTHER
}

enum TimeEntryStatus {
  OPEN
  SUBMITTED
  APPROVED
  REJECTED
}

// ---------- Sales pipeline enums ----------

enum QuoteStatus {
  DRAFT
  SENT
  CHANGES_REQUESTED
  REVISED
  NEGOTIATING
  ACCEPTED
  CONVERTED
  LOST
  EXPIRED
}

enum QuoteEventKind {
  SENT
  CLIENT_VIEWED
  ALTERATION_REQUESTED
  CUSTOMIZATION_REQUESTED
  NEGOTIATION
  REVISION_ISSUED
  ACCEPTED
  REJECTED
  NOTE
}

enum POStatus {
  DRAFT
  ISSUED
  CANCELLED
}

enum ProjectStageKey {
  SURVEY
  DELIVERY
  INSTALL
  COMMISSION
  HANDOVER
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  DONE
  BLOCKED
}

enum InvoiceKind {
  ADVANCE
  PROGRESS
  FINAL
  ADHOC
  AMC_CONTRACT
  AMC_INSTALLMENT
  SERVICE_CALL
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

// ---------- Core identity ----------

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  passwordHash   String
  role           Role
  employmentType EmploymentType?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  rateCards          EmployeeRateCard[]
  timeEntries        TimeEntry[]          @relation("EmployeeEntries")
  approvedEntries    TimeEntry[]          @relation("ApproverEntries")
  supervisedProjects Project[]            @relation("SiteSupervisor")
  stockIssues        StockIssue[]
  overheadAllocs     OverheadAllocation[]
  auditLogs          AuditLog[]
  materialTransfers  MaterialTransfer[]   @relation("TransferredBy")
  quotesCreated      Quote[]              @relation("QuoteCreatedBy")
  quoteEvents        QuoteEvent[]         @relation("QuoteEventActor")
  clientInvoices     ClientInvoice[]      @relation("ClientInvoiceCreatedBy")
  milestonesUpdated  ProjectMilestone[]   @relation("MilestoneUpdatedBy")
  posSigned          PurchaseOrder[]      @relation("POSignedBy")
  mobileSessions     MobileSession[]      @relation("MobileSessions")
  mobileOps          MobileOp[]           @relation("MobileOps")
  mobileDevices      MobileDevice[]       @relation("MobileDevices")
  vendorPosApproved  VendorPO[]           @relation("VendorPOApprovedBy")
  grnsReceived       GRN[]                @relation("GRNReceivedBy")
  vendorBillsMatched VendorBill[]         @relation("VendorBillMatchedBy")
  amcsApproved       AMC[]                @relation("AMCApprovedBy")
  amcVisitsAssigned  AMCVisit[]           @relation("AMCVisitAssignee")
  serviceIssuesAssigned ServiceIssue[]    @relation("ServiceIssueAssignee")
  serviceIssuesClosed   ServiceIssue[]    @relation("ServiceIssueClosedBy")
  serviceIssuesTriaged  ServiceIssue[]    @relation("ServiceIssueTriagedBy")
  serviceVisitsAssigned ServiceVisit[]    @relation("ServiceVisitAssignee")
  indentsRequested      MaterialIndent[]  @relation("IndentRequester")
  indentsApproved       MaterialIndent[]  @relation("IndentApprover")
}

model EmployeeRateCard {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          EmploymentType
  hourlyRate    Decimal?       @db.Decimal(10, 2)
  monthlySalary Decimal?       @db.Decimal(12, 2)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime       @default(now())

  @@index([userId, effectiveFrom])
}

// ---------- Clients (new) ----------

model Client {
  id              String   @id @default(cuid())
  name            String
  gstin           String?
  pan             String?
  billingAddress  String
  shippingAddress String?
  stateCode       String // 2-digit GST state code, e.g. "29" for Karnataka
  contactName     String?
  email           String?
  phone           String?
  notes           String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projects       Project[]
  quotes         Quote[]
  clientInvoices ClientInvoice[]
  amcs           AMC[]
  serviceIssues  ServiceIssue[]

  @@unique([name, gstin])
  @@index([name])
  @@index([active])
}

// ---------- Projects & budget ----------

model Project {
  id               String        @id @default(cuid())
  code             String        @unique
  name             String
  clientName       String // legacy/display string; kept for back-compat
  clientId         String?
  client           Client?       @relation(fields: [clientId], references: [id])
  status           ProjectStatus @default(DRAFT)
  contractValue    Decimal       @db.Decimal(14, 2)
  startDate        DateTime?
  endDate          DateTime?
  siteSupervisorId String?
  siteSupervisor   User?         @relation("SiteSupervisor", fields: [siteSupervisorId], references: [id])
  poDate           DateTime?
  poStatus         POStatus?
  poNumber         String?
  fileNo           String?
  location         String?
  description      String?
  projectDetails   String?
  workStatus       String?
  billedValue      Decimal       @default(0) @db.Decimal(14, 2)
  adjBillableValue Decimal       @default(0) @db.Decimal(14, 2)
  materialsSupplied Decimal?     @db.Decimal(14, 2)
  response         String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  budgetLines     BudgetLine[]
  timeEntries     TimeEntry[]
  stockIssues     StockIssue[]
  directPurchases DirectPurchase[]
  overheadAllocs  OverheadAllocation[]
  invoices        Invoice[]
  transfersOut    MaterialTransfer[]   @relation("TransfersFrom")
  transfersIn     MaterialTransfer[]   @relation("TransfersTo")
  quote           Quote?               @relation("QuoteConvertedProject")
  purchaseOrder   PurchaseOrder?
  stages          ProjectStage[]
  milestones      ProjectMilestone[]
  clientInvoices  ClientInvoice[]
  vendorPos       VendorPO[]
  amcs            AMC[]
  serviceIssues   ServiceIssue[]
  indents         MaterialIndent[]

  @@index([status])
  @@index([siteSupervisorId])
  @@index([clientId])
}

model BudgetLine {
  id          String         @id @default(cuid())
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category    BudgetCategory
  description String
  // Optional binding to a specific Material SKU. When set, the indent
  // budget-check matches against this line by materialId. Legacy free-text
  // budget lines (materialId = null) don't grant in-budget allowance and
  // their indents fall through to ADMIN approval.
  materialId  String?
  material    Material?      @relation(fields: [materialId], references: [id])
  quantity    Decimal        @db.Decimal(12, 3)
  unitCost    Decimal        @db.Decimal(12, 2)
  total       Decimal        @db.Decimal(14, 2)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([projectId, category])
  @@index([projectId, materialId])
}

// ---------- Time & labor ----------

model TimeEntry {
  id         String          @id @default(cuid())
  employeeId String
  employee   User            @relation("EmployeeEntries", fields: [employeeId], references: [id])
  projectId  String
  project    Project         @relation(fields: [projectId], references: [id])
  clockIn    DateTime
  clockOut   DateTime?
  minutes    Int?
  note       String?
  geoInLat   Decimal?        @db.Decimal(9, 6)
  geoInLng   Decimal?        @db.Decimal(9, 6)
  geoOutLat  Decimal?        @db.Decimal(9, 6)
  geoOutLng  Decimal?        @db.Decimal(9, 6)
  photoUrls  String[]        @default([])
  status     TimeEntryStatus @default(OPEN)
  approverId String?
  approver   User?           @relation("ApproverEntries", fields: [approverId], references: [id])
  approvedAt DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([employeeId, clockIn])
  @@index([projectId, clockIn])
  @@index([status])
}

// ---------- Mobile app (REST API, JWT sessions, offline replay) ----------

// Refresh-token store for the mobile REST API. Short-lived access JWTs are
// signed stateless; the long-lived refresh token hash is persisted here so we
// can rotate and revoke without relying on a NextAuth cookie that won't
// survive an iOS WKWebView cold start.
model MobileSession {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation("MobileSessions", fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String   @unique
  deviceId         String
  expiresAt        DateTime
  lastUsedAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([deviceId])
}

// Idempotency log for offline-queue replay. Every mutating mobile call sends a
// client-generated UUID (`clientOpId`) and we cache the response so a replayed
// op returns the same result instead of creating a duplicate TimeEntry.
model MobileOp {
  id        String   @id // clientOpId (UUID) generated on device
  userId    String
  user      User     @relation("MobileOps", fields: [userId], references: [id], onDelete: Cascade)
  kind      String // 'punchIn' | 'punchOut' | 'switch' | 'submit'
  result    Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// FCM / APNs token registry so the server can push approval / submission
// notifications. One user may have multiple devices; tokens rotate silently,
// so we upsert on the token itself.
model MobileDevice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("MobileDevices", fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String // 'ios' | 'android'
  appVersion String?
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId])
}

// ---------- Inventory ----------

model Material {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  unit        String
  openingQty     Decimal @default(0) @db.Decimal(14, 3)
  openingAvgCost Decimal @default(0) @db.Decimal(12, 4)
  onHandQty      Decimal @default(0) @db.Decimal(14, 3)
  avgUnitCost    Decimal @default(0) @db.Decimal(12, 4)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  receipts     StockReceipt[]
  issues       StockIssue[]
  transfers    MaterialTransfer[]
  indentLines  MaterialIndentLine[]
  budgetLines  BudgetLine[]
}

model StockReceipt {
  id         String   @id @default(cuid())
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  qty        Decimal  @db.Decimal(14, 3)
  unitCost   Decimal  @db.Decimal(12, 4)
  supplier   String?
  receivedAt DateTime
  note       String?
  createdAt  DateTime @default(now())

  @@index([materialId, receivedAt])
}

model StockIssue {
  id              String   @id @default(cuid())
  materialId      String
  material        Material @relation(fields: [materialId], references: [id])
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  qty             Decimal  @db.Decimal(14, 3)
  unitCostAtIssue Decimal  @db.Decimal(12, 4)
  issuedById      String
  issuedBy        User     @relation(fields: [issuedById], references: [id])
  issuedAt        DateTime
  note            String?
  amcVisitId      String?  @unique
  amcVisit        AMCVisit?     @relation(fields: [amcVisitId], references: [id])
  serviceVisitId  String?  @unique
  serviceVisit    ServiceVisit? @relation(fields: [serviceVisitId], references: [id])
  // Backref when this issue was created to fulfill an indent line. Lets us
  // trace any StockIssue back to the request it satisfied; nullable so
  // direct issues (issued-without-indent) keep working.
  indentLineId    String?
  indentLine      MaterialIndentLine? @relation(fields: [indentLineId], references: [id])
  createdAt       DateTime @default(now())

  @@index([projectId, issuedAt])
  @@index([materialId, issuedAt])
  @@index([indentLineId])
}

model DirectPurchase {
  id          String         @id @default(cuid())
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id])
  description String
  qty         Decimal        @db.Decimal(14, 3)
  unitCost    Decimal        @db.Decimal(12, 2)
  total       Decimal        @db.Decimal(14, 2)
  supplier    String?
  purchasedAt DateTime
  invoiceRef  String?
  category    BudgetCategory @default(MATERIAL)
  createdAt   DateTime       @default(now())

  @@index([projectId, purchasedAt])
}

model OverheadAllocation {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  periodMonth DateTime
  amount      Decimal  @db.Decimal(14, 2)
  note        String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, periodMonth])
  @@index([periodMonth])
}

model Invoice {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  invoiceNo String   @unique
  amount    Decimal  @db.Decimal(14, 2)
  issuedAt  DateTime
  note      String?
  createdAt DateTime @default(now())

  @@index([projectId, issuedAt])
}

model MaterialTransfer {
  id                 String   @id @default(cuid())
  materialId         String
  material           Material @relation(fields: [materialId], references: [id])
  fromProjectId      String
  fromProject        Project  @relation("TransfersFrom", fields: [fromProjectId], references: [id])
  toProjectId        String
  toProject          Project  @relation("TransfersTo", fields: [toProjectId], references: [id])
  qty                Decimal  @db.Decimal(14, 3)
  unitCostAtTransfer Decimal  @db.Decimal(12, 4)
  transferredById    String
  transferredBy      User     @relation("TransferredBy", fields: [transferredById], references: [id])
  transferredAt      DateTime
  note               String?
  createdAt          DateTime @default(now())

  @@index([fromProjectId, transferredAt])
  @@index([toProjectId, transferredAt])
  @@index([materialId, transferredAt])
}

// ---------- Material indents (PM → Storekeeper request flow) ----------
// PM raises an indent against a project; budget check at submit time decides
// whether storekeeper can issue directly (in budget) or whether ADMIN needs
// to approve (over budget). Lines support partial issuance — a line stays
// open until issuedQty reaches requestedQty.

enum MaterialIndentStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PARTIALLY_ISSUED
  ISSUED
  CANCELLED
}

model MaterialIndent {
  id              String               @id @default(cuid())
  indentNo        String               @unique // e.g. "IND-26-27-0001"
  projectId       String
  project         Project              @relation(fields: [projectId], references: [id])
  requestedById   String
  requestedBy     User                 @relation("IndentRequester", fields: [requestedById], references: [id])
  status          MaterialIndentStatus @default(DRAFT)
  needsApproval   Boolean              @default(false) // computed at submit
  approvedById    String?
  approvedBy      User?                @relation("IndentApprover", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectionReason String?
  notes           String?
  submittedAt     DateTime?
  closedAt        DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  lines MaterialIndentLine[]

  @@index([status])
  @@index([projectId, status])
  @@index([requestedById])
}

model MaterialIndentLine {
  id                String   @id @default(cuid())
  indentId          String
  indent            MaterialIndent @relation(fields: [indentId], references: [id], onDelete: Cascade)
  materialId        String
  material          Material @relation(fields: [materialId], references: [id])
  requestedQty      Decimal  @db.Decimal(14, 3)
  unitCostSnapshot  Decimal  @db.Decimal(12, 4)
  isInBudget        Boolean  @default(true)
  reasonOutOfBudget String?
  issuedQty         Decimal  @default(0) @db.Decimal(14, 3)
  notes             String?

  stockIssues StockIssue[]

  @@index([indentId])
  @@index([materialId])
}

model IndentNumberSequence {
  year Int @id
  next Int @default(1)
}

// ---------- Sales pipeline (new) ----------

model Quote {
  id                     String      @id @default(cuid())
  quoteNo                String      @unique
  clientId               String
  client                 Client      @relation(fields: [clientId], references: [id])
  projectId              String?     @unique
  project                Project?    @relation("QuoteConvertedProject", fields: [projectId], references: [id])
  title                  String
  status                 QuoteStatus @default(DRAFT)
  version                Int         @default(1)
  parentQuoteId          String?
  parentQuote            Quote?      @relation("QuoteRevisions", fields: [parentQuoteId], references: [id])
  revisions              Quote[]     @relation("QuoteRevisions")
  validUntil             DateTime?
  placeOfSupplyStateCode String
  subtotal               Decimal     @default(0) @db.Decimal(14, 2)
  taxTotal               Decimal     @default(0) @db.Decimal(14, 2)
  grandTotal             Decimal     @default(0) @db.Decimal(14, 2)
  notes                  String?
  termsMd                String?
  createdById            String
  createdBy              User        @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  sentAt                 DateTime?
  acceptedAt             DateTime?
  convertedAt            DateTime?
  shareToken             String      @unique

  lines  QuoteLine[]
  events QuoteEvent[]
  po     PurchaseOrder?

  @@index([status])
  @@index([clientId])
  @@index([createdAt])
}

model QuoteLine {
  id           String         @id @default(cuid())
  quoteId      String
  quote        Quote          @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  sortOrder    Int
  category     BudgetCategory
  description  String
  hsnSac       String?
  quantity     Decimal        @db.Decimal(12, 3)
  unit         String
  unitPrice    Decimal        @db.Decimal(12, 2)
  discountPct  Decimal        @default(0) @db.Decimal(5, 2)
  gstRatePct   Decimal        @default(0) @db.Decimal(5, 2)
  lineSubtotal Decimal        @db.Decimal(14, 2)
  lineTax      Decimal        @db.Decimal(14, 2)
  lineTotal    Decimal        @db.Decimal(14, 2)

  @@index([quoteId, sortOrder])
}

model QuoteEvent {
  id          String         @id @default(cuid())
  quoteId     String
  quote       Quote          @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  kind        QuoteEventKind
  note        String?
  fromStatus  QuoteStatus?
  toStatus    QuoteStatus?
  actorUserId String?
  actor       User?          @relation("QuoteEventActor", fields: [actorUserId], references: [id])
  at          DateTime       @default(now())

  @@index([quoteId, at])
}

model PurchaseOrder {
  id             String    @id @default(cuid())
  poNo           String    @unique
  projectId      String    @unique
  project        Project   @relation(fields: [projectId], references: [id])
  quoteId        String    @unique
  quote          Quote     @relation(fields: [quoteId], references: [id])
  status         POStatus  @default(ISSUED)
  issuedAt       DateTime  @default(now())
  signedByUserId String?
  signedBy       User?     @relation("POSignedBy", fields: [signedByUserId], references: [id])
  signedAt       DateTime?
  clientPoNumber String?
  clientPoDate   DateTime?
  plannedStart   DateTime
  plannedEnd     DateTime
  amount         Decimal   @db.Decimal(14, 2)
  snapshotJson   Json
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
}

// ---------- Project progress (new) ----------

model ProjectStage {
  id           String          @id @default(cuid())
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageKey     ProjectStageKey
  plannedStart DateTime?
  plannedEnd   DateTime?
  actualStart  DateTime?
  actualEnd    DateTime?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([projectId, stageKey])
}

model ProjectMilestone {
  id              String          @id @default(cuid())
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageKey        ProjectStageKey
  sortOrder       Int
  name            String
  plannedStart    DateTime?
  plannedEnd      DateTime?
  actualStart     DateTime?
  actualEnd       DateTime?
  percentComplete Decimal         @default(0) @db.Decimal(5, 2)
  weight          Decimal         @default(1) @db.Decimal(6, 2)
  status          MilestoneStatus @default(PENDING)
  updatedByUserId String?
  updatedBy       User?           @relation("MilestoneUpdatedBy", fields: [updatedByUserId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([projectId, stageKey, sortOrder])
}

// ---------- Client-facing (GST) invoicing (new) ----------

model ClientInvoice {
  id                     String        @id @default(cuid())
  invoiceNo              String        @unique
  kind                   InvoiceKind
  status                 InvoiceStatus @default(DRAFT)
  projectId              String
  project                Project       @relation(fields: [projectId], references: [id])
  clientId               String
  client                 Client        @relation(fields: [clientId], references: [id])
  placeOfSupplyStateCode String
  issuedAt               DateTime?
  dueAt                  DateTime?
  subtotal               Decimal       @default(0) @db.Decimal(14, 2)
  cgst                   Decimal       @default(0) @db.Decimal(14, 2)
  sgst                   Decimal       @default(0) @db.Decimal(14, 2)
  igst                   Decimal       @default(0) @db.Decimal(14, 2)
  taxTotal               Decimal       @default(0) @db.Decimal(14, 2)
  grandTotal             Decimal       @default(0) @db.Decimal(14, 2)
  amountPaid             Decimal       @default(0) @db.Decimal(14, 2)
  paidAt                 DateTime?
  notes                  String?
  termsMd                String?
  poRef                  String?
  createdById            String
  createdBy              User          @relation("ClientInvoiceCreatedBy", fields: [createdById], references: [id])
  shareToken             String        @unique
  amcId                  String?
  amc                    AMC?          @relation(fields: [amcId], references: [id])
  serviceIssueId         String?       @unique
  serviceIssue           ServiceIssue? @relation(fields: [serviceIssueId], references: [id])
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  lines ClientInvoiceLine[]

  @@index([projectId, issuedAt])
  @@index([status])
  @@index([status, issuedAt])
  @@index([clientId])
  @@index([amcId])
  @@index([createdAt])
}

model ClientInvoiceLine {
  id           String        @id @default(cuid())
  invoiceId    String
  invoice      ClientInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sortOrder    Int
  description  String
  hsnSac       String?
  quantity     Decimal       @db.Decimal(12, 3)
  unit         String
  unitPrice    Decimal       @db.Decimal(12, 2)
  discountPct  Decimal       @default(0) @db.Decimal(5, 2)
  gstRatePct   Decimal       @default(0) @db.Decimal(5, 2)
  lineSubtotal Decimal       @db.Decimal(14, 2)
  lineTax      Decimal       @db.Decimal(14, 2)
  lineTotal    Decimal       @db.Decimal(14, 2)

  @@index([invoiceId, sortOrder])
}

// ---------- Audit & sequences ----------

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String
  payloadHash String?
  at          DateTime @default(now())

  @@index([entity, entityId])
  @@index([at])
}

model ProjectCodeSequence {
  year Int @id
  next Int @default(1)
}

model QuoteNumberSequence {
  year Int @id
  next Int @default(1)
}

model PONumberSequence {
  year Int @id
  next Int @default(1)
}

model ClientInvoiceNumberSequence {
  year Int @id
  next Int @default(1)
}

// ---------- Procurement (Vendors → POs → GRNs → Vendor bills) ----------
// Vendor-facing side of purchasing. Note: the existing `PurchaseOrder` model
// above is the *client-facing* PO attached to accepted quotes. The models below
// cover supplier POs we raise against vendors, goods-receipt notes on delivery,
// and the three-way-matched bills we pay.

enum VendorCategory {
  PIPES
  FITTINGS
  PUMPS
  VALVES
  SPRINKLERS
  TOOLS
  CONSUMABLES
  SERVICES
  OTHER
}

enum VendorPaymentTerms {
  NET_15
  NET_30
  NET_45
  NET_60
  ADVANCE
}

enum VendorPOStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

enum GRNStatus {
  DRAFT
  ACCEPTED
  PARTIALLY_ACCEPTED
  REJECTED
}

enum VendorBillStatus {
  DRAFT
  PENDING_MATCH
  MATCHED
  DISCREPANCY
  APPROVED
  PAID
  OVERDUE
}

model Vendor {
  id             String             @id @default(cuid())
  code           String             @unique // e.g. "V-1042"
  name           String
  gstin          String?
  pan            String?
  stateCode      String // 2-digit GST state code ("27" etc.)
  category       VendorCategory     @default(OTHER)
  msme           Boolean            @default(false)
  contactName    String?
  phone          String?
  email          String?
  address        String?
  paymentTerms   VendorPaymentTerms @default(NET_30)
  creditLimit    Decimal            @default(0) @db.Decimal(14, 2)
  notes          String?
  active         Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  purchaseOrders VendorPO[]
  bills          VendorBill[]

  @@index([active])
  @@index([category])
  @@index([name])
}

model VendorPO {
  id                String         @id @default(cuid())
  poNo              String         @unique // e.g. "PO-1042"
  vendorId          String
  vendor            Vendor         @relation(fields: [vendorId], references: [id])
  projectId         String?
  project           Project?       @relation(fields: [projectId], references: [id])
  status            VendorPOStatus @default(DRAFT)
  issueDate         DateTime       @default(now())
  expectedDate      DateTime?
  subtotal          Decimal        @default(0) @db.Decimal(14, 2)
  taxTotal          Decimal        @default(0) @db.Decimal(14, 2)
  grandTotal        Decimal        @default(0) @db.Decimal(14, 2)
  approvalTier      String // 'auto' | 'pm' | 'director' — derived from amount
  approvedByUserId  String?
  approvedBy        User?          @relation("VendorPOApprovedBy", fields: [approvedByUserId], references: [id])
  approvedAt        DateTime?
  sentAt            DateTime?
  closedAt          DateTime?
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  lines VendorPOLine[]
  grns  GRN[]
  bills VendorBill[]

  @@index([status])
  @@index([vendorId, issueDate])
  @@index([projectId])
}

model VendorPOLine {
  id             String   @id @default(cuid())
  poId           String
  po             VendorPO @relation(fields: [poId], references: [id], onDelete: Cascade)
  sortOrder      Int
  sku            String
  description    String
  unit           String // 'm', 'kg', 'pcs' etc.
  quantity       Decimal  @db.Decimal(14, 3)
  unitPrice      Decimal  @db.Decimal(12, 2)
  gstRatePct     Decimal  @default(0) @db.Decimal(5, 2)
  lineSubtotal   Decimal  @db.Decimal(14, 2)
  lineTax        Decimal  @db.Decimal(14, 2)
  lineTotal      Decimal  @db.Decimal(14, 2)
  receivedQty    Decimal  @default(0) @db.Decimal(14, 3)

  grnLines       GRNLine[] @relation("GRNLineToPOLine")

  @@index([poId, sortOrder])
}

model GRN {
  id             String    @id @default(cuid())
  grnNo          String    @unique // e.g. "GRN-0231"
  poId           String
  po             VendorPO  @relation(fields: [poId], references: [id])
  status         GRNStatus @default(DRAFT)
  receivedAt     DateTime  @default(now())
  receivedByUserId String?
  receivedBy     User?     @relation("GRNReceivedBy", fields: [receivedByUserId], references: [id])
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  lines GRNLine[]

  @@index([poId, receivedAt])
  @@index([status])
}

model GRNLine {
  id             String       @id @default(cuid())
  grnId          String
  grn            GRN          @relation(fields: [grnId], references: [id], onDelete: Cascade)
  poLineId       String
  poLine         VendorPOLine @relation("GRNLineToPOLine", fields: [poLineId], references: [id])
  sortOrder      Int
  orderedQty     Decimal      @db.Decimal(14, 3)
  acceptedQty    Decimal      @db.Decimal(14, 3)
  rejectedQty    Decimal      @default(0) @db.Decimal(14, 3)
  reason         String?

  @@index([grnId, sortOrder])
  @@index([poLineId])
}

model VendorBill {
  id               String           @id @default(cuid())
  billNo           String           @unique // internal number, e.g. "VB-0512"
  vendorBillNo     String? // the vendor's invoice number as printed
  vendorId         String
  vendor           Vendor           @relation(fields: [vendorId], references: [id])
  poId             String?
  po               VendorPO?        @relation(fields: [poId], references: [id])
  status           VendorBillStatus @default(DRAFT)
  issueDate        DateTime         @default(now())
  dueDate          DateTime?
  subtotal         Decimal          @default(0) @db.Decimal(14, 2)
  taxTotal         Decimal          @default(0) @db.Decimal(14, 2)
  grandTotal       Decimal          @default(0) @db.Decimal(14, 2)
  amountPaid       Decimal          @default(0) @db.Decimal(14, 2)
  paidAt           DateTime?
  matchedByUserId  String?
  matchedBy        User?            @relation("VendorBillMatchedBy", fields: [matchedByUserId], references: [id])
  matchedAt        DateTime?
  discrepancyNote  String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  lines VendorBillLine[]

  @@index([status])
  @@index([vendorId, issueDate])
  @@index([dueDate])
}

model VendorBillLine {
  id             String     @id @default(cuid())
  billId         String
  bill           VendorBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  sortOrder      Int
  description    String
  quantity       Decimal    @db.Decimal(14, 3)
  unit           String
  unitPrice      Decimal    @db.Decimal(12, 2)
  gstRatePct     Decimal    @default(0) @db.Decimal(5, 2)
  lineSubtotal   Decimal    @db.Decimal(14, 2)
  lineTax        Decimal    @db.Decimal(14, 2)
  lineTotal      Decimal    @db.Decimal(14, 2)

  @@index([billId, sortOrder])
}

model VendorCodeSequence {
  year Int @id
  next Int @default(1)
}

model VendorPONumberSequence {
  year Int @id
  next Int @default(1)
}

model GRNNumberSequence {
  year Int @id
  next Int @default(1)
}

model VendorBillNumberSequence {
  year Int @id
  next Int @default(1)
}

// ---------- After-sales (AMC contracts + Service issues) ----------
// Covers two adjacent revenue streams: preventive maintenance under annual
// contracts (AMC), and reactive service callouts raised between visits. Both
// share a technician-visit primitive and a coverage decision (AMC/warranty/
// goodwill/billable).

enum AMCType {
  COMPREHENSIVE
  NON_COMPREHENSIVE
  LABOUR_ONLY
}

enum AMCBillingMode {
  ANNUAL
  INSTALLMENTS
  PER_VISIT
}

enum AMCStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  ON_HOLD
  EXPIRED
  CANCELLED
  RENEWED
}

enum AMCFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum AMCVisitStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  MISSED
  CANCELLED
}

enum ServiceChannel {
  PHONE
  WHATSAPP
  EMAIL
  PORTAL
  WALK_IN
}

// Priority default SLA: P1 = 4h, P2 = 24h, P3 = 72h, P4 = 7d. Per-AMC
// overrides live in the AMCSLA child table.
enum ServicePriority {
  P1
  P2
  P3
  P4
}

enum ServiceCategory {
  LEAK
  BURST
  BLOCKAGE
  PUMP_FAILURE
  VALVE_FAILURE
  SPRINKLER_HEAD
  ELECTRICAL
  GENERAL
}

enum ServiceStatus {
  NEW
  TRIAGED
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  VERIFIED
  CLOSED
  CANCELLED
}

enum ServiceCoverage {
  AMC
  WARRANTY
  GOODWILL
  BILLABLE
}

model AMC {
  id               String         @id @default(cuid())
  contractNo       String         @unique // e.g. "AMC-25-26-1042"
  title            String
  clientId         String
  client           Client         @relation(fields: [clientId], references: [id])
  projectId        String
  project          Project        @relation(fields: [projectId], references: [id])
  type             AMCType        @default(COMPREHENSIVE)
  billingMode      AMCBillingMode @default(ANNUAL)
  status           AMCStatus      @default(DRAFT)
  startDate        DateTime
  endDate          DateTime
  frequency        AMCFrequency   @default(QUARTERLY)
  visitsPerYear    Int            @default(4)
  annualValue      Decimal        @default(0) @db.Decimal(14, 2)
  taxPct           Decimal        @default(18) @db.Decimal(5, 2)
  grandTotal       Decimal        @default(0) @db.Decimal(14, 2)
  approvedByUserId String?
  approvedBy       User?          @relation("AMCApprovedBy", fields: [approvedByUserId], references: [id])
  approvedAt       DateTime?
  activatedAt      DateTime?
  cancelledAt      DateTime?
  parentAmcId      String?
  parentAmc        AMC?           @relation("AMCRenewal", fields: [parentAmcId], references: [id])
  renewals         AMC[]          @relation("AMCRenewal")
  siteAddress      String
  assetsCovered    Json // array of { name, qty?, notes? }
  exclusions       String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  slas          AMCSLA[]
  visits        AMCVisit[]
  serviceIssues ServiceIssue[]
  invoices      ClientInvoice[]

  @@index([status])
  @@index([clientId, startDate])
  @@index([projectId])
  @@index([endDate])
}

model AMCSLA {
  id              String          @id @default(cuid())
  amcId           String
  amc             AMC             @relation(fields: [amcId], references: [id], onDelete: Cascade)
  priority        ServicePriority
  responseHours   Int
  resolutionHours Int

  @@unique([amcId, priority])
}

model AMCVisit {
  id                 String         @id @default(cuid())
  amcId              String
  amc                AMC            @relation(fields: [amcId], references: [id], onDelete: Cascade)
  visitNo            Int // 1-indexed within contract
  scheduledDate      DateTime
  status             AMCVisitStatus @default(SCHEDULED)
  assignedToUserId   String?
  assignedTo         User?          @relation("AMCVisitAssignee", fields: [assignedToUserId], references: [id])
  startedAt          DateTime?
  completedAt        DateTime?
  checklist          Json? // array of { item, ok, note }
  findings           String?
  photoUrls          String[]       @default([])
  geoLat             Decimal?       @db.Decimal(9, 6)
  geoLng             Decimal?       @db.Decimal(9, 6)
  partsUsed          Json? // array of { sku, description, qty, unit }
  notes              String?
  offlineClientOpId  String?        @unique
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  stockIssue StockIssue?

  @@unique([amcId, visitNo])
  @@index([scheduledDate, status])
  @@index([assignedToUserId, status])
}

model ServiceIssue {
  id                       String          @id @default(cuid())
  ticketNo                 String          @unique // e.g. "SR-25-26-0231"
  clientId                 String
  client                   Client          @relation(fields: [clientId], references: [id])
  projectId                String
  project                  Project         @relation(fields: [projectId], references: [id])
  amcId                    String?
  amc                      AMC?            @relation(fields: [amcId], references: [id])
  reportedAt               DateTime
  reportedByName           String
  reportedByPhone          String?
  channel                  ServiceChannel  @default(PHONE)
  siteAddress              String
  summary                  String
  description              String?
  attachmentUrls           String[]        @default([])
  category                 ServiceCategory @default(GENERAL)
  priority                 ServicePriority @default(P3)
  coverage                 ServiceCoverage @default(BILLABLE)
  coverageOverrideReason   String?
  responseDueAt            DateTime?
  resolutionDueAt          DateTime?
  firstResponseAt          DateTime?
  resolvedAt               DateTime?
  slaBreachedAt            DateTime?
  onHoldSince              DateTime?
  onHoldCumulativeMinutes  Int             @default(0)
  status                   ServiceStatus   @default(NEW)
  assignedToUserId         String?
  assignedTo               User?           @relation("ServiceIssueAssignee", fields: [assignedToUserId], references: [id])
  triagedByUserId          String?
  triagedBy                User?           @relation("ServiceIssueTriagedBy", fields: [triagedByUserId], references: [id])
  triagedAt                DateTime?
  closedAt                 DateTime?
  closedByUserId           String?
  closedBy                 User?           @relation("ServiceIssueClosedBy", fields: [closedByUserId], references: [id])
  closureNotes             String?
  clientSignoffName        String?
  clientSignoffAt          DateTime?
  billableAmount           Decimal?        @db.Decimal(14, 2)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  visits  ServiceVisit[]
  invoice ClientInvoice?

  @@index([status, priority])
  @@index([status, resolutionDueAt])
  @@index([clientId, reportedAt])
  @@index([projectId])
  @@index([assignedToUserId, status])
  @@index([resolutionDueAt])
  @@index([slaBreachedAt])
}

model ServiceVisit {
  id                String       @id @default(cuid())
  serviceIssueId    String
  serviceIssue      ServiceIssue @relation(fields: [serviceIssueId], references: [id], onDelete: Cascade)
  assignedToUserId  String?
  assignedTo        User?        @relation("ServiceVisitAssignee", fields: [assignedToUserId], references: [id])
  scheduledAt       DateTime?
  arrivedAt         DateTime?
  completedAt       DateTime?
  findings          String?
  workPerformed     String?
  partsUsed         Json? // array of { sku, description, qty, unit }
  photoUrls         String[]     @default([])
  geoLat            Decimal?     @db.Decimal(9, 6)
  geoLng            Decimal?     @db.Decimal(9, 6)
  signatureUrl      String?
  offlineClientOpId String?      @unique
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  stockIssue StockIssue?

  @@index([serviceIssueId])
  @@index([assignedToUserId, scheduledAt])
}

model AMCNumberSequence {
  year Int @id
  next Int @default(1)
}

model ServiceTicketNumberSequence {
  year Int @id
  next Int @default(1)
}

// ---------- AI agent (cost + audit log) ----------
// Every LLM call records a row here so `cost-guard.ts` can enforce a
// per-user daily token budget and we retain a hashed fingerprint of each
// prompt (PII stripped upstream by `redact.ts`) for auditability. Not FK-
// linked to User so the row survives user deletion for post-hoc audit.

model AIPromptLog {
  id         String   @id @default(cuid())
  userId     String?
  feature    String
  promptHash String
  modelName  String
  inputTok   Int
  outputTok  Int
  costInr    Decimal  @db.Decimal(10, 4)
  success    Boolean
  errorCode  String?
  at         DateTime @default(now())

  @@index([userId, at])
  @@index([feature, at])
}
