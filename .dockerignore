# SAB India Tracker — Docker build context exclusions for the Next.js image.
# Anything not listed here is shipped to the Docker daemon, so be precise.

# --- Local artifacts (rebuilt inside the container) ---
node_modules
.next
.next-*
dist
dist-mobile
out

# --- Mobile / native (web deploy doesn't need them) ---
android
ios
capacitor.config.ts

# --- Source control / editors / OS noise ---
.git
.github
.gitignore
.claude
.vscode
.idea
.DS_Store
Thumbs.db

# --- Tests + coverage (not run inside the deploy image) ---
coverage
test-results
playwright-report
tests
playwright.config.ts
vitest.config.ts

# --- Static-HTML demo (separate deploy story; not part of Next.js app) ---
server.py
SAB India Tracker.html

# --- Docs / handoff / scripts ---
docs
sab_handoff
scripts
HANDOVER.md
DEPLOY.md

# --- Secrets / local env (Railway provides them at runtime) ---
.env
.env.*
.env.local

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*

# --- TS / Next ambient files (regenerated during build) ---
tsconfig.tsbuildinfo
next-env.d.ts

# --- Don't ship public/uploads (per-tenant runtime data) ---
public/uploads
